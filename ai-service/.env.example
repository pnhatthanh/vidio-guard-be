# ── AI Service Environment Variables ───────────────────────────────────────
# All vars are prefixed with AI_ (see app/config.py)

# Model
AI_MODEL_PATH=models/efficientnet.keras
AI_IMG_SIZE=224
AI_BATCH_SIZE=32
AI_LABELS=["nsfw","safe","violence"]

# Server
AI_HOST=0.0.0.0
AI_PORT=8000
AI_WORKERS=1
AI_LOG_LEVEL=info

# CORS
AI_CORS_ORIGINS=["*"]

# faster-whisper
AUDIO_WHISPER_MODEL_SIZE=large-v3
AUDIO_WHISPER_LANGUAGE=vi
AUDIO_WHISPER_INITIAL_PROMPT=
AUDIO_WHISPER_BEAM_SIZE=5
# false when Silero VAD preprocess is enabled
AUDIO_WHISPER_USE_BUILTIN_VAD=false

# Pre-ASR pipeline (DeepFilterNet → Silero → Whisper)
AUDIO_PREPROCESS_ENABLED=true
AUDIO_PREPROCESS_DENOISE=true
AUDIO_PREPROCESS_SILERO_VAD=true
# Heavy — enable only for loud background music (TikTok/livestream)
AUDIO_PREPROCESS_DEMUCS=false
AUDIO_SILERO_THRESHOLD=0.5
AUDIO_CHUNK_MAX_SEC=30

# PhoBERT weights
AUDIO_PHOBERT_MODEL_PATH=models
AUDIO_PORT=8001
